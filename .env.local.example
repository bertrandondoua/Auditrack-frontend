# Auditrack API base URL (Django REST + django-oauth-toolkit)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public origin of the deployed frontend. Used for metadataBase + canonical /
# Open Graph URLs. Falls back to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth2 password-grant client credentials issued by Auditrack-api.
# Used by /redux/features/auth/authApiSlice.ts when calling /auth/token/.
NEXT_PUBLIC_CLIENT_ID=
NEXT_PUBLIC_CLIENT_SECRET=
